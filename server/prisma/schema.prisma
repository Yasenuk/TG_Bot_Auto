generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id                 Int      @id @default(autoincrement())
  name               String
  amortizationPerKm  Float

  trips              Trip[]
}

model City {
  id      Int        @id @default(autoincrement())
  name    String

  trips   TripCity[]
}

model Trip {
  id                 Int        @id @default(autoincrement())

  userId             BigInt
  username           String?

  carId              Int
  car                Car        @relation(fields: [carId], references: [id])

  consumption        Float
  fuelPrice          Float
  totalKm            Float

  amortizationCost   Float
  fuelUsed           Float
  fuelCost           Float

  createdAt          DateTime   @default(now())

  cities             TripCity[]
}

model TripCity {
  id          Int     @id @default(autoincrement())

  tripId      Int
  trip        Trip    @relation(fields: [tripId], references: [id])

  cityId      Int
  city        City    @relation(fields: [cityId], references: [id])

  amortizationCost Float
  fuelCost         Float
}