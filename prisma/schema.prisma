generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Trip {
  id                Int      @id @default(autoincrement())
  userId            Int
  carName           String

  amortizationPerKm Float
  fuelPrice         Float
  consumption       Float
  totalKm           Float

  totalAmortization Float
  totalFuelLiters   Float
  totalFuelCost     Float

  createdAt         DateTime @default(now())

  cities            TripCity[]
}

model City {
  id    Int    @id @default(autoincrement())
  name  String

  trips TripCity[]
}

model TripCity {
  id Int @id @default(autoincrement())

  tripId Int
  cityId Int

  amortizationShare Float
  fuelCostShare     Float
  fuelLitersShare   Float

  trip Trip @relation(fields: [tripId], references: [id])
  city City @relation(fields: [cityId], references: [id])
}